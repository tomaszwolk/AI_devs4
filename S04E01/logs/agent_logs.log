er-spacing: 0.08em;\n            font-weight: 700;\n            color: #111111;\n            text-transform: uppercase;\n            text-align: center;\n            line-height: 1;\n        }\n\n        .ticket--torn-right::after,\n        .ticket--torn-left::before {\n            content: '';\n            position: absolute;\n            top: -2px;\n            bottom: -2px;\n            width: 34px;\n            background:\n                radial-gradient(13px 11px at 0 8px, transparent 97%, #e7dcc2 100%) 0 0 / 100% 34px repeat-y,\n                radial-gradient(9px 8px at 100% 25px, #ede3cc 98%, transparent 100%) 0 0 / 100% 34px repeat-y,\n                linear-gradient(180deg, #f9f2dd 0%, #eadfbe 100%);\n            filter: drop-shadow(0 1px 0 rgba(0, 0, 0, 0.08));\n            border-radius: 22px;\n        }\n\n        .ticket--torn-right::after {\n            right: -18px;\n            clip-path: polygon(0 0, 64% 3%, 92% 9%, 68% 17%, 100% 25%, 70% 34%, 96% 43%, 66% 53%, 100% 62%, 73% 71%, 95% 80%, 62% 89%, 84% 95%, 0 100%);\n        }\n\n        .ticket--torn-left::before {\n            left: -18px;\n            clip-path: polygon(100% 0, 36% 3%, 8% 9%, 32% 17%, 0 25%, 30% 34%, 4% 43%, 34% 53%, 0 62%, 27% 71%, 5% 80%, 38% 89%, 16% 95%, 100% 100%);\n        }\n\n        .trap-card {\n            width: min(80vw, 1280px);\n            min-height: min(80vh, 920px);\n            display: flex;\n            flex-direction: column;\n            justify-content: center;\n            gap: 24px;\n        }\n\n        .trap-video-wrap {\n            width: 100%;\n            border: 1px solid var(--border);\n            border-radius: 18px;\n            overflow: hidden;\n            background: #000000;\n            aspect-ratio: 16 / 9;\n        }\n\n        .trap-video {\n            width: 100%;\n            height: 100%;\n            border: 0;\n            display: block;\n        }\n\n        @media (max-width: 840px) {\n            .shell {\n                width: min(100% - 24px, 1184px);\n                margin: 12px auto;\n            }\n\n            .topbar,\n            .panel,\n            .login-card {\n                padding: 24px;\n                border-radius: 24px;\n            }\n\n            .apikey-chip {\n                max-width: 100%;\n            }\n\n            .trap-card {\n                width: min(100%, 760px);\n                min-height: auto;\n                padding: 20px;\n                gap: 16px;\n            }\n\n            .trap-video-wrap {\n                border-radius: 14px;\n            }\n        }\n    </style>\n</head>\n<body>\n    <main class=\"login-wrap\">\n        <section class=\"login-card\">\n            <p class=\"eyebrow\">OKO secure console</p>\n            <h1 class=\"login-title\">Logowanie operatora</h1>\n            <p class=\"login-copy\">\n                Podaj dane operatora oraz klucz dostępu, aby otworzyć środowisko robocze.\n            </p>\n\n            \n            <form method=\"post\" class=\"login-form\" action=\"/\">\n                <input type=\"hidden\" name=\"action\" value=\"login\">\n\n                <label>\n                    <span class=\"field-label\">Login</span>\n                    <input class=\"field-input\" type=\"text\" name=\"login\" value=\"admin\" autocomplete=\"username\" required>\n                </label>\n\n                <label>\n                    <span class=\"field-label\">Hasło</span>\n                    <input class=\"field-input\" type=\"password\" name=\"password\" autocomplete=\"current-password\" required>\n                </label>\n\n                <label>\n                    <span class=\"field-label\">Klucz dostępu</span>\n                    <input class=\"field-input\" type=\"text\" name=\"access_key\" placeholder=\"xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx\" required>\n                </label>\n\n                <button class=\"submit-button\" type=\"submit\">Zaloguj</button>\n            </form>\n        </section>\n    </main>\n</body>\n</html>\n"}

